{
  "version": 2,
  "public": true,
  "framework": null,
  "installCommand": "bash install-flutter.sh",
  "buildCommand": "flutter/bin/flutter build web --release",
  "outputDirectory": "build/web",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}